    {"type":"text","id":"zaBatcht","x":136,"y":174,"width":440,"height":294,"text":"struct ProofSystemBatch...Entries {\n  ExecutionEntry[]  entries;\n  LookupCall[]      l1ToL2lookupCalls;\n  uint256 transientExecutionEntryCount;\n  uint256 transientLookupCallCount;\n  address[] proofSystems;          // sorted asc\n  RollupIdWithProofSystems[]\n          rollupIdsWithProofSystems; // asc by id\n  uint256[] blobIndices;\n  bytes     callData;\n  bytes[]   proofs;                // one per PS\n  uint64    blockNumber;\n}\n\nstruct RollupIdWithProofSystems {\n  uint256  rollupId;\n  uint64[] proofSystemIndex;       // into proofSystems[]\n}","originalText":"struct ProofSystemBatch...Entries {\n  ExecutionEntry[]  entries;\n  LookupCall[]      l1ToL2lookupCalls;\n  uint256 transientExecutionEntryCount;\n  uint256 transientLookupCallCount;\n  address[] proofSystems;          // sorted asc\n  RollupIdWithProofSystems[]\n          rollupIdsWithProofSystems; // asc by id\n  uint256[] blobIndices;\n  bytes     callData;\n  bytes[]   proofs;                // one per PS\n  uint64    blockNumber;\n}\n\nstruct RollupIdWithProofSystems {\n  uint256  rollupId;\n  uint64[] proofSystemIndex;       // into proofSystems[]\n}","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":610012,"version":1,"versionNonce":610013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.42},

