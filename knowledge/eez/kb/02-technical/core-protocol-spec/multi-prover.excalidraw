    {"type":"text","id":"zaCap","x":620,"y":408,"width":390,"height":72,"text":"Each rollup lists a strictly-ascending subset of\nproofSystems[] — len ≥ its own threshold. The batch\nverifies exactly proofSystems.length proofs; all must\nverify atomically (one revert reverts the whole call).","originalText":"Each rollup lists a strictly-ascending subset of\nproofSystems[] — len ≥ its own threshold. The batch\nverifies exactly proofSystems.length proofs; all must\nverify atomically (one revert reverts the whole call).","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":610090,"version":1,"versionNonce":610091,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

