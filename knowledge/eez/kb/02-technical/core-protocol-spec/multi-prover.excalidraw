    {"type":"text","id":"zbS1t","x":1096,"y":174,"width":440,"height":108,"text":"Stage 1 — shared (folded once):\n\nsharedPublicInput = keccak256(\n    entryHashes, lookupCallHashes,\n    blobHashes, keccak(callData),\n    customDataAcc )","originalText":"Stage 1 — shared (folded once):\n\nsharedPublicInput = keccak256(\n    entryHashes, lookupCallHashes,\n    blobHashes, keccak(callData),\n    customDataAcc )","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":620012,"version":1,"versionNonce":620013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"rectangle","id":"zbS2","x":1580,"y":160,"width":480,"height":136,"strokeColor":"#13263d","backgroundColor":"#1e3a5f","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":620020,"version":1,"versionNonce":620021,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zbS2t","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zbS2t","x":1596,"y":174,"width":450,"height":108,"text":"Stage 2 — per proof-system k:\n\n  acc_k = fold(rollupId, vkey) over\n      rollups whose subset includes k\n  publicInputsHash[k] =\n      keccak256(sharedPublicInput, acc_k)","originalText":"Stage 2 — per proof-system k:\n\n  acc_k = fold(rollupId, vkey) over\n      rollups whose subset includes k\n  publicInputsHash[k] =\n      keccak256(sharedPublicInput, acc_k)","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":620022,"version":1,"versionNonce":620023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

