    {"type":"text","id":"zcNote","x":120,"y":892,"width":880,"height":54,"text":"Both done in ONE external call per rollup — no TOCTOU between two reads, no central threshold semantics.\nCustom managers may use any threshold model (fixed M-of-N, governance-driven, time-weighted...). The\nregistry just consumes the returned vkeys.","originalText":"Both done in ONE external call per rollup — no TOCTOU between two reads, no central threshold semantics.\nCustom managers may use any threshold model (fixed M-of-N, governance-driven, time-weighted...). The\nregistry just consumes the returned vkeys.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":630060,"version":1,"versionNonce":630061,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

