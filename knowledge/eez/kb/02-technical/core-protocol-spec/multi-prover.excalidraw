    {"type":"text","id":"zbNote","x":1080,"y":606,"width":980,"height":20,"text":"customData (shared, folded once) does NOT vary per PS — only acc_k does. All proofs verify atomically; any failure reverts the batch.","originalText":"customData (shared, folded once) does NOT vary per PS — only acc_k does. All proofs verify atomically; any failure reverts the batch.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":620130,"version":1,"versionNonce":620131,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.3},

