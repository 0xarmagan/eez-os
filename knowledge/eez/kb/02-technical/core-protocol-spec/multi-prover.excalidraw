    {"type":"text","id":"zdHdr","x":1080,"y":694,"width":600,"height":24,"text":"D · Trust model & what was removed","originalText":"D · Trust model & what was removed","fontSize":20,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640002,"version":1,"versionNonce":640003,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"rectangle","id":"zdTrust","x":1080,"y":736,"width":470,"height":210,"strokeColor":"#1e40af","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640010,"version":1,"versionNonce":640011,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zdTrustt","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zdTrustt","x":1096,"y":750,"width":440,"height":182,"text":"Trust model\n\n• Each rollup = its own security domain —\n   manager compromise affects only that rollup's\n   state root + queue, never others'.\n• The rollup owner trusts its own proof\n   system(s) and threshold.\n• Atomic verification across the batch.\n• The orchestrator pays for any waste\n   (unrelated PSes, unconsumed entries).","originalText":"Trust model\n\n• Each rollup = its own security domain —\n   manager compromise affects only that rollup's\n   state root + queue, never others'.\n• The rollup owner trusts its own proof\n   system(s) and threshold.\n• Atomic verification across the batch.\n• The orchestrator pays for any waste\n   (unrelated PSes, unconsumed entries).","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640012,"version":1,"versionNonce":640013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

    {"type":"rectangle","id":"zdRem","x":1590,"y":736,"width":470,"height":210,"strokeColor":"#b91c1c","backgroundColor":"#fee2e2","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640020,"version":1,"versionNonce":640021,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zdRemt","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zdRemt","x":1606,"y":750,"width":440,"height":182,"text":"Removed in this refactor\n\n✗  ProofSystemRegistry (central registry)\n✗  IZKVerifier → IProofSystem (generalised)\n✗  RollupConfig.owner / threshold / proofSystemCount\n✗  EEZ.setVerificationKey / addProofSystem /\n     setThreshold / transferRollupOwnership\n✗  _inPostBatch flag (→ length check)\n✗  global executions[] / executionIndex","originalText":"Removed in this refactor\n\n✗  ProofSystemRegistry (central registry)\n✗  IZKVerifier → IProofSystem (generalised)\n✗  RollupConfig.owner / threshold / proofSystemCount\n✗  EEZ.setVerificationKey / addProofSystem /\n     setThreshold / transferRollupOwnership\n✗  _inPostBatch flag (→ length check)\n✗  global executions[] / executionIndex","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b91c1c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640022,"version":1,"versionNonce":640023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35}
