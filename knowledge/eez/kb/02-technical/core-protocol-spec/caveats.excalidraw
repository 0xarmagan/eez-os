    {"type":"text","id":"q4b1t","x":1062,"y":688,"width":778,"height":20,"text":"delegatecall · balance · extcodesize · extcodecopy · …","originalText":"delegatecall · balance · extcodesize · extcodecopy · …","fontSize":14,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":540012,"version":1,"versionNonce":540013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"q4b1","lineHeight":1.25},
    {"type":"text","id":"q4g2","x":1048,"y":740,"width":806,"height":36,"text":"Block-state opcodes reflect the EXECUTING chain, not the source —\nvalues differ when the same action is observed on L1 vs L2:","originalText":"Block-state opcodes reflect the EXECUTING chain, not the source —\nvalues differ when the same action is observed on L1 vs L2:","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":540014,"version":1,"versionNonce":540015,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},
