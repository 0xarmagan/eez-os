    {"type":"text","id":"q4ttl","x":1048,"y":606,"width":810,"height":24,"text":"4 · Opcodes differ on cross-chain proxies","originalText":"4 · Opcodes differ on cross-chain proxies","fontSize":19,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b45309","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":540003,"version":1,"versionNonce":540004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"q4g1","x":1048,"y":648,"width":806,"height":18,"text":"Return info about the PROXY, not the proxied contract:","originalText":"Return info about the PROXY, not the proxied contract:","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":540005,"version":1,"versionNonce":540006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
