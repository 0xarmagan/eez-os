    {"type":"text","id":"q4b2t","x":1062,"y":798,"width":778,"height":20,"text":"blocknumber · blockhash · blockgaslimit · chainid · coinbase · …","originalText":"blocknumber · blockhash · blockgaslimit · chainid · coinbase · …","fontSize":14,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":540022,"version":1,"versionNonce":540023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"q4b2","lineHeight":1.25},
    {"type":"text","id":"q4note","x":1048,"y":850,"width":806,"height":36,"text":"A cross-chain proxy is a local stand-in: opcodes that read \"who/where am I\" answer\nfor the proxy and its chain, not the remote contract being represented.","originalText":"A cross-chain proxy is a local stand-in: opcodes that read \"who/where am I\" answer\nfor the proxy and its chain, not the remote contract being represented.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":540024,"version":1,"versionNonce":540025,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35}
