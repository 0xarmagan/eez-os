    {"type":"text","id":"q1cap","x":456,"y":324,"width":500,"height":34,"text":"e1 reverts → blocks here.\nCursor frozen; e2 / e3 unreachable.","originalText":"e1 reverts → blocks here.\nCursor frozen; e2 / e3 unreachable.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b91c1c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":510026,"version":1,"versionNonce":510027,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.3},

    {"type":"line","id":"q1div","x":148,"y":382,"width":804,"height":0,"strokeColor":"#fcd34d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"dashed","roughness":0,"opacity":100,"angle":0,"seed":510028,"version":1,"versionNonce":510029,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"points":[[0,0],[804,0]]},
    {"type":"text","id":"q1exc","x":148,"y":394,"width":804,"height":150,"text":"Exception — the IMMEDIATE prefix (proxyEntryHash == 0):\nattemptApplyImmediate wraps each entry in try/catch, so a reverting candidate emits\nImmediateEntrySkipped and the cursor STILL advances. Alternatives gated by\nStateDelta.currentState CAN be stacked here — only the one matching the live root applies.","originalText":"Exception — the IMMEDIATE prefix (proxyEntryHash == 0):\nattemptApplyImmediate wraps each entry in try/catch, so a reverting candidate emits\nImmediateEntrySkipped and the cursor STILL advances. Alternatives gated by\nStateDelta.currentState CAN be stacked here — only the one matching the live root applies.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#047857","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":510030,"version":1,"versionNonce":510031,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

    {"type":"rectangle","id":"q2","x":1020,"y":150,"width":860,"height":410,"strokeColor":"#b45309","backgroundColor":"#ffffff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":520001,"version":1,"versionNonce":520002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"q2ttl","x":1048,"y":166,"width":810,"height":24,"text":"2 · The transient phase is self-contained","originalText":"2 · The transient phase is self-contained","fontSize":19,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b45309","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":520003,"version":1,"versionNonce":520004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"q2body","x":1048,"y":202,"width":806,"height":80,"text":"While a postAndVerifyBatch is mid-flight, ALL resolution is served from that batch's\nown transient tables — execution entries AND top-level lookups never fall through to\nthe persistent per-rollup queues. Consequence: cross-rollup interaction inside the\nmeta hook works ONLY between rollups verified TOGETHER in the same batch.","originalText":"While a postAndVerifyBatch is mid-flight, ALL resolution is served from that batch's\nown transient tables — execution entries AND top-level lookups never fall through to\nthe persistent per-rollup queues. Consequence: cross-rollup interaction inside the\nmeta hook works ONLY between rollups verified TOGETHER in the same batch.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":520005,"version":1,"versionNonce":520006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

