    {"type":"text","id":"q3ttl","x":148,"y":606,"width":810,"height":24,"text":"3 · Indistinguishable revert reasons","originalText":"3 · Indistinguishable revert reasons","fontSize":19,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b45309","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530003,"version":1,"versionNonce":530004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"q3body","x":148,"y":646,"width":804,"height":44,"text":"A caller (contract or EOA) cannot tell apart two cases when calling a proxy.\nBoth bubble up identically as a revert from the proxy:","originalText":"A caller (contract or EOA) cannot tell apart two cases when calling a proxy.\nBoth bubble up identically as a revert from the proxy:","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530005,"version":1,"versionNonce":530006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

    {"type":"rectangle","id":"q3ca","x":148,"y":706,"width":370,"height":72,"strokeColor":"#1e40af","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530010,"version":1,"versionNonce":530011,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"q3cat","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"q3cat","x":162,"y":720,"width":342,"height":44,"text":"no matching entry in the\nexecution table","originalText":"no matching entry in the\nexecution table","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530012,"version":1,"versionNonce":530013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"q3ca","lineHeight":1.3},
    {"type":"rectangle","id":"q3cb","x":582,"y":706,"width":370,"height":72,"strokeColor":"#1e40af","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530014,"version":1,"versionNonce":530015,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"q3cbt","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"q3cbt","x":596,"y":720,"width":342,"height":44,"text":"destination call itself\nreverted","originalText":"destination call itself\nreverted","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530016,"version":1,"versionNonce":530017,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"q3cb","lineHeight":1.3},
    {"type":"text","id":"q3eq","x":520,"y":726,"width":60,"height":30,"text":"=","originalText":"=","fontSize":26,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#b45309","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530018,"version":1,"versionNonce":530019,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"q3note","x":148,"y":802,"width":804,"height":40,"text":"There is no on-chain way to distinguish them — both surface as the same proxy revert.\nDesign callers that do not branch on \"why\" the proxy reverted.","originalText":"There is no on-chain way to distinguish them — both surface as the same proxy revert.\nDesign callers that do not branch on \"why\" the proxy reverted.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":530020,"version":1,"versionNonce":530021,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

