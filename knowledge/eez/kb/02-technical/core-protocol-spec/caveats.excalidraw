    {"type":"text","id":"ttl","x":120,"y":34,"width":900,"height":36,"text":"EEZ Core Protocol — Caveats & Edge Cases","originalText":"EEZ Core Protocol — Caveats & Edge Cases","fontSize":30,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":500001,"version":1,"versionNonce":500002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"sub","x":120,"y":76,"width":1000,"height":20,"text":"Source: eez-core-protocol/docs/CAVEATS.md  ·  four behaviours that surprise builders","originalText":"Source: eez-core-protocol/docs/CAVEATS.md  ·  four behaviours that surprise builders","fontSize":15,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":500003,"version":1,"versionNonce":500004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"rectangle","id":"q1","x":120,"y":150,"width":860,"height":410,"strokeColor":"#b45309","backgroundColor":"#ffffff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":510001,"version":1,"versionNonce":510002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"q1ttl","x":148,"y":166,"width":810,"height":24,"text":"1 · One deterministic consumption order","originalText":"1 · One deterministic consumption order","fontSize":19,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b45309","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":510003,"version":1,"versionNonce":510004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"q1body","x":148,"y":202,"width":804,"height":96,"text":"Each rollup's executionQueue encodes exactly ONE valid order. An entry that reverts\nmid-execution (StateRootMismatch, RollingHashMismatch...) reverts the whole consuming\ntx WITHOUT advancing the cursor — it BLOCKS the queue rather than being skipped.\nPublishing several candidate entries and letting \"whichever succeeds\" apply does\nNOT work in the persistent path.","originalText":"Each rollup's executionQueue encodes exactly ONE valid order. An entry that reverts\nmid-execution (StateRootMismatch, RollingHashMismatch...) reverts the whole consuming\ntx WITHOUT advancing the cursor — it BLOCKS the queue rather than being skipped.\nPublishing several candidate entries and letting \"whichever succeeds\" apply does\nNOT work in the persistent path.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":510005,"version":1,"versionNonce":510006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

