    {"type":"text","id":"ttl","x":120,"y":30,"width":900,"height":38,"text":"EEZ Core Protocol — Lookup Spec","originalText":"EEZ Core Protocol — Lookup Spec","fontSize":30,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":800001,"version":1,"versionNonce":800002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"sub","x":120,"y":74,"width":1200,"height":20,"text":"Source: eez-core-protocol/docs/LOOKUP_SPEC.md  ·  a call that is looked up, not executed — because it is read-only or it reverts","originalText":"Source: eez-core-protocol/docs/LOOKUP_SPEC.md  ·  a call that is looked up, not executed — because it is read-only or it reverts","fontSize":15,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":800003,"version":1,"versionNonce":800004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"zaHdr","x":120,"y":120,"width":700,"height":24,"text":"A · Two structs, two homes","originalText":"A · Two structs, two homes","fontSize":20,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810001,"version":1,"versionNonce":810002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

