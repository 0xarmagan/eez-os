    {"type":"text","id":"zdEt","x":1131,"y":824,"width":450,"height":98,"text":"executingLookupIndex:  0 = host level;\nk = inside sub-execution of expectedLookups[k-1].\nCompared vs live context\n(_insideRevertedLookup ? _revertedLookupIndex+1 : 0)\n— ENFORCED on-chain (was a prover convention).","originalText":"executingLookupIndex:  0 = host level;\nk = inside sub-execution of expectedLookups[k-1].\nCompared vs live context\n(_insideRevertedLookup ? _revertedLookupIndex+1 : 0)\n— ENFORCED on-chain (was a prover convention).","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":840022,"version":1,"versionNonce":840023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"rectangle","id":"zdT","x":1615,"y":648,"width":490,"height":108,"strokeColor":"#13263d","backgroundColor":"#1e3a5f","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":840030,"version":1,"versionNonce":840031,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zdTt","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zdTt","x":1631,"y":662,"width":460,"height":80,"text":"TOP-LEVEL match (L1):\n  crossChainCallHash +\n  every expectedStateRoots[] pin ==\n     live rollups[rollupId].stateRoot\n  (L2: crossChainCallHash alone)","originalText":"TOP-LEVEL match (L1):\n  crossChainCallHash +\n  every expectedStateRoots[] pin ==\n     live rollups[rollupId].stateRoot\n  (L2: crossChainCallHash alone)","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":840032,"version":1,"versionNonce":840033,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"rectangle","id":"zdP","x":1615,"y":770,"width":490,"height":166,"strokeColor":"#1e40af","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":840040,"version":1,"versionNonce":840041,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zdPt","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zdPt","x":1631,"y":784,"width":460,"height":138,"text":"State-root pins replace the old queue-cursor pins:\n\n• Split-independent — roots don't depend on the\n   transient / persistent split.\n• Transient-phase capable — roots advance entry-\n   by-entry during the batch.\n• Re-verify robust — same-block re-verify resets\n   cursors, but the root trajectory continues.","originalText":"State-root pins replace the old queue-cursor pins:\n\n• Split-independent — roots don't depend on the\n   transient / persistent split.\n• Transient-phase capable — roots advance entry-\n   by-entry during the batch.\n• Re-verify robust — same-block re-verify resets\n   cursors, but the root trajectory continues.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":840042,"version":1,"versionNonce":840043,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4}
