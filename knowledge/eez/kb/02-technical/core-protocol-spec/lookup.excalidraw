    {"type":"rectangle","id":"zaTh","x":600,"y":166,"width":450,"height":40,"strokeColor":"#6d28d9","backgroundColor":"#ddd6fe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810022,"version":1,"versionNonce":810023,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zaTht","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zaTht","x":610,"y":177,"width":430,"height":20,"text":"TOP-LEVEL — LookupCall","originalText":"TOP-LEVEL — LookupCall","fontSize":15,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#4c1d95","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810024,"version":1,"versionNonce":810025,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"zaTh","lineHeight":1.25},
    {"type":"text","id":"zaTb","x":618,"y":222,"width":416,"height":250,"text":"Lives in:\n   the storage pool — _transientLookupCalls /\n   per-rollup lookupQueue (L1); lookupCalls (L2)\n\nServes:\n   top-level static reads, and\n   top-level reverting calls\n\nMatch key:\n   crossChainCallHash + state-root pins (L1);\n   hash alone (L2)\n\nConsumable when:\n   !_insideExecution()  (outside any execution)","originalText":"Lives in:\n   the storage pool — _transientLookupCalls /\n   per-rollup lookupQueue (L1); lookupCalls (L2)\n\nServes:\n   top-level static reads, and\n   top-level reverting calls\n\nMatch key:\n   crossChainCallHash + state-root pins (L1);\n   hash alone (L2)\n\nConsumable when:\n   !_insideExecution()  (outside any execution)","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810026,"version":1,"versionNonce":810027,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"rectangle","id":"zaIns","x":120,"y":498,"width":930,"height":56,"strokeColor":"#b45309","backgroundColor":"#fef3c7","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810030,"version":1,"versionNonce":810031,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zaInst","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zaInst","x":136,"y":510,"width":900,"height":36,"text":"Entry-scoping is structural: a nested lookup resolves ONLY from the entry (or executed top-level lookup) that carries it —\nno queue routing, no cross-entry collisions, no cross-rollup routing concerns.","originalText":"Entry-scoping is structural: a nested lookup resolves ONLY from the entry (or executed top-level lookup) that carries it —\nno queue routing, no cross-entry collisions, no cross-rollup routing concerns.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810032,"version":1,"versionNonce":810033,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

