    {"type":"text","id":"zdNt","x":1131,"y":662,"width":450,"height":120,"text":"NESTED match — 4-tuple:\n( crossChainCallHash,\n  l2ToL1CallNumber,        // _currentL2ToL1Call\n  lastL1ToL2CallConsumed,  // _lastL1ToL2CallConsumed\n  executingLookupIndex )","originalText":"NESTED match — 4-tuple:\n( crossChainCallHash,\n  l2ToL1CallNumber,        // _currentL2ToL1Call\n  lastL1ToL2CallConsumed,  // _lastL1ToL2CallConsumed\n  executingLookupIndex )","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":840012,"version":1,"versionNonce":840013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.45},

