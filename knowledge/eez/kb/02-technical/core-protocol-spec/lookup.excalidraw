    {"type":"text","id":"zaNht","x":130,"y":177,"width":430,"height":20,"text":"NESTED — ExpectedLookup","originalText":"NESTED — ExpectedLookup","fontSize":15,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810014,"version":1,"versionNonce":810015,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"zaNh","lineHeight":1.25},
    {"type":"text","id":"zaNb","x":138,"y":222,"width":416,"height":250,"text":"Lives in:\n   ExecutionEntry.expectedLookups[]\n   (+ a top-level lookup's own table)\n\nServes:\n   reentrant static reads, and\n   try/catch'd reverting reentrant calls\n\nMatch key:\n   4-tuple (see D) — entry-scoped\n\nConsumable when:\n   _insideExecution() == true","originalText":"Lives in:\n   ExecutionEntry.expectedLookups[]\n   (+ a top-level lookup's own table)\n\nServes:\n   reentrant static reads, and\n   try/catch'd reverting reentrant calls\n\nMatch key:\n   4-tuple (see D) — entry-scoped\n\nConsumable when:\n   _insideExecution() == true","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":810016,"version":1,"versionNonce":810017,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

