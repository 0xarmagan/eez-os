    {"type":"text","id":"zcRHt","x":2026,"y":514,"width":360,"height":202,"text":"single rollingHash per entry —\ntags folded as each call runs:\n\n  CALL_BEGIN    = 1\n  CALL_END      = 2  (success, retData)\n  NESTED_BEGIN  = 3\n  NESTED_END    = 4\n\nrequire(_rollingHash == entry.rollingHash)\n          → RollingHashMismatch","originalText":"single rollingHash per entry —\ntags folded as each call runs:\n\n  CALL_BEGIN    = 1\n  CALL_END      = 2  (success, retData)\n  NESTED_BEGIN  = 3\n  NESTED_END    = 4\n\nrequire(_rollingHash == entry.rollingHash)\n          → RollingHashMismatch","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":300152,"version":1,"versionNonce":300153,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

