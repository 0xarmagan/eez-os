    {"type":"text","id":"zaNotet","x":134,"y":742,"width":372,"height":68,"text":"Each rollup = its own security domain.\nNo central prover registry. Threshold is\nper-rollup configurable (M-of-N), enforced\nin the manager — NOT a fixed minimum.","originalText":"Each rollup = its own security domain.\nNo central prover registry. Threshold is\nper-rollup configurable (M-of-N), enforced\nin the manager — NOT a fixed minimum.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":100072,"version":1,"versionNonce":100073,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"zaNote","lineHeight":1.3},

