    {"type":"text","id":"zbEvt","x":636,"y":320,"width":320,"height":186,"text":"struct ProofSystemBatch...Entries {\n  ExecutionEntry[]  entries;\n  LookupCall[]      l1ToL2lookupCalls;\n  uint256 transientExecutionEntryCount;\n  address[] proofSystems;     // sorted\n  RollupIdWithProofSystems[]  ...;\n  uint256[] blobIndices;\n  bytes     callData;\n  bytes[]   proofs;           // one per PS\n  uint64    blockNumber;\n}","originalText":"struct ProofSystemBatch...Entries {\n  ExecutionEntry[]  entries;\n  LookupCall[]      l1ToL2lookupCalls;\n  uint256 transientExecutionEntryCount;\n  address[] proofSystems;     // sorted\n  RollupIdWithProofSystems[]  ...;\n  uint256[] blobIndices;\n  bytes     callData;\n  bytes[]   proofs;           // one per PS\n  uint64    blockNumber;\n}","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200012,"version":1,"versionNonce":200013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

