    {"type":"text","id":"zdHdr","x":1140,"y":580,"width":700,"height":24,"text":"D · Entry kinds & the 1-to-1 rule","originalText":"D · Entry kinds & the 1-to-1 rule","fontSize":20,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":740002,"version":1,"versionNonce":740003,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"rectangle","id":"zdImm","x":1140,"y":628,"width":470,"height":146,"strokeColor":"#1e40af","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":740010,"version":1,"versionNonce":740011,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zdImmt","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zdImmt","x":1156,"y":642,"width":440,"height":118,"text":"IMMEDIATE  (proxyEntryHash == 0)\nLeading transient entries run inline inside\npostAndVerifyBatch via attemptApplyImmediate\n(try/catch → ImmediateEntrySkipped, cursor still\nadvances). L1-only — pure L2 txs and L2-touch-L1.","originalText":"IMMEDIATE  (proxyEntryHash == 0)\nLeading transient entries run inline inside\npostAndVerifyBatch via attemptApplyImmediate\n(try/catch → ImmediateEntrySkipped, cursor still\nadvances). L1-only — pure L2 txs and L2-touch-L1.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":740012,"version":1,"versionNonce":740013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

    {"type":"rectangle","id":"zdDef","x":1140,"y":788,"width":470,"height":134,"strokeColor":"#1e40af","backgroundColor":"#dbeafe","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":740020,"version":1,"versionNonce":740021,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zdDeft","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zdDeft","x":1156,"y":802,"width":440,"height":106,"text":"DEFERRED  (proxyEntryHash != 0)\nConsumed by executeCrossChainCall /\nexecuteL2TX in posted order, only in the block\nposted (lastVerifiedBlock == block.number).\nCursor advance is per-rollup.","originalText":"DEFERRED  (proxyEntryHash != 0)\nConsumed by executeCrossChainCall /\nexecuteL2TX in posted order, only in the block\nposted (lastVerifiedBlock == block.number).\nCursor advance is per-rollup.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":740022,"version":1,"versionNonce":740023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

    {"type":"rectangle","id":"zd11","x":1640,"y":628,"width":490,"height":294,"strokeColor":"#b45309","backgroundColor":"#fef3c7","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":740030,"version":1,"versionNonce":740031,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zd11t","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zd11t","x":1656,"y":644,"width":460,"height":266,"text":"The 1-to-1 rule\n\nEach user action produces EXACTLY one execution\ntx per chain involved.\n\n• L1→L2: user calls a proxy on L1 (1 tx); the\n   system delivers on L2 via\n   executeIncomingCrossChainCall (1 tx).\n• L2→L1: the L2 user tx is the L2 consumption;\n   the immediate entry is consumed inline on L1.\n\nReentrant calls fold into the SAME tx via\nexpectedL1ToL2Calls[]. Never split one\ninteraction into multiple txs on one chain.","originalText":"The 1-to-1 rule\n\nEach user action produces EXACTLY one execution\ntx per chain involved.\n\n• L1→L2: user calls a proxy on L1 (1 tx); the\n   system delivers on L2 via\n   executeIncomingCrossChainCall (1 tx).\n• L2→L1: the L2 user tx is the L2 consumption;\n   the immediate entry is consumed inline on L1.\n\nReentrant calls fold into the SAME tx via\nexpectedL1ToL2Calls[]. Never split one\ninteraction into multiple txs on one chain.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":740032,"version":1,"versionNonce":740033,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35}
  ],
