    {"type":"text","id":"zaHdr","x":120,"y":120,"width":600,"height":24,"text":"A · ExecutionEntry anatomy (L1 vs L2)","originalText":"A · ExecutionEntry anatomy (L1 vs L2)","fontSize":20,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":710001,"version":1,"versionNonce":710002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"rectangle","id":"zaL1","x":120,"y":162,"width":330,"height":300,"strokeColor":"#13263d","backgroundColor":"#1e3a5f","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":710010,"version":1,"versionNonce":710011,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zaL1t","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zaL1t","x":136,"y":176,"width":300,"height":272,"text":"struct ExecutionEntry {   // L1\n  StateDelta[] stateDeltas;     // L1-only\n  bytes32  proxyEntryHash;      // 0 = immediate\n  uint256  destinationRollupId; // L1-only\n  L2ToL1Call[] l2ToL1Calls;     // flat array\n  ExpectedL1ToL2Call[]\n           expectedL1ToL2Calls;\n  ExpectedLookup[] expectedLookups;\n  uint256  callCount;\n  bytes    returnData;\n  bytes32  rollingHash;\n}","originalText":"struct ExecutionEntry {   // L1\n  StateDelta[] stateDeltas;     // L1-only\n  bytes32  proxyEntryHash;      // 0 = immediate\n  uint256  destinationRollupId; // L1-only\n  L2ToL1Call[] l2ToL1Calls;     // flat array\n  ExpectedL1ToL2Call[]\n           expectedL1ToL2Calls;\n  ExpectedLookup[] expectedLookups;\n  uint256  callCount;\n  bytes    returnData;\n  bytes32  rollingHash;\n}","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":710012,"version":1,"versionNonce":710013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.45},

    {"type":"rectangle","id":"zaL2","x":470,"y":162,"width":330,"height":300,"strokeColor":"#13263d","backgroundColor":"#1e3a5f","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":710020,"version":1,"versionNonce":710021,"isDeleted":false,"groupIds":[],"boundElements":[{"id":"zaL2t","type":"text"}],"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"zaL2t","x":486,"y":176,"width":300,"height":272,"text":"struct ExecutionEntry {   // L2\n  bytes32  proxyEntryHash;     // never 0\n  CrossChainCall[] incomingCalls;\n  ExpectedOutgoingCrossChainCall[]\n           expectedOutgoingCalls;\n  ExpectedLookup[] expectedLookups;\n  uint256  callCount;\n  bytes    returnData;\n  bytes32  rollingHash;\n}\n\n// NO stateDeltas / destinationRollupId\n// self-relative names: counterparty\n// can be L1 OR another L2","originalText":"struct ExecutionEntry {   // L2\n  bytes32  proxyEntryHash;     // never 0\n  CrossChainCall[] incomingCalls;\n  ExpectedOutgoingCrossChainCall[]\n           expectedOutgoingCalls;\n  ExpectedLookup[] expectedLookups;\n  uint256  callCount;\n  bytes    returnData;\n  bytes32  rollingHash;\n}\n\n// NO stateDeltas / destinationRollupId\n// self-relative names: counterparty\n// can be L1 OR another L2","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":710022,"version":1,"versionNonce":710023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.45},

    {"type":"text","id":"zaCap","x":120,"y":474,"width":680,"height":54,"text":"Top-level entries always succeed (executeCrossChainCall returns entry.returnData) — there is no entry.failed\nflag. Reverts are expressed as lookups. Every L1 entry must carry ≥1 StateDelta (prover obligation); its\ncurrentState is the soundness backstop checked at consumption.","originalText":"Top-level entries always succeed (executeCrossChainCall returns entry.returnData) — there is no entry.failed\nflag. Reverts are expressed as lookups. Every L1 entry must carry ≥1 StateDelta (prover obligation); its\ncurrentState is the soundness backstop checked at consumption.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":710030,"version":1,"versionNonce":710031,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

