    {"type":"text","id":"zbOrder","x":884,"y":256,"width":760,"height":18,"text":"execution order:  c0 begins → ⟨reentrant: c1, c2⟩ → c0 ends → c3 → c4","originalText":"execution order:  c0 begins → ⟨reentrant: c1, c2⟩ → c0 ends → c3 → c4","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":720080,"version":1,"versionNonce":720081,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
