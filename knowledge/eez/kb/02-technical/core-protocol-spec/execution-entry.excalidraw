    {"type":"text","id":"zbInvt","x":900,"y":336,"width":590,"height":90,"text":"PARTITION INVARIANT:\n  callCount  +  Σ expectedL1ToL2Calls[i].callCount  ==  l2ToL1Calls.length\n      3      +                   2                  ==          5     ✓\n\nNot a separate check — falls out of the two end-of-entry cursor equalities.","originalText":"PARTITION INVARIANT:\n  callCount  +  Σ expectedL1ToL2Calls[i].callCount  ==  l2ToL1Calls.length\n      3      +                   2                  ==          5     ✓\n\nNot a separate check — falls out of the two end-of-entry cursor equalities.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#bfdbfe","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":720092,"version":1,"versionNonce":720093,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"text","id":"zbNote","x":884,"y":454,"width":620,"height":36,"text":"Reentrant calls share the SAME flat array and the SAME cursor (_currentL2ToL1Call). Semantic\nstructure comes from callCount, never from positional grouping.","originalText":"Reentrant calls share the SAME flat array and the SAME cursor (_currentL2ToL1Call). Semantic\nstructure comes from callCount, never from positional grouping.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":720094,"version":1,"versionNonce":720095,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

