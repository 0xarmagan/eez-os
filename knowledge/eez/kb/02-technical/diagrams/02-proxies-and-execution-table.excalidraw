    {"type":"text","id":"footer","x":150,"y":430,"width":1100,"height":48,"text":"A bridge connects two separate states. A proxy exposes one state in two places.\nProxies are synchronous and share state: no wrapped assets, no relayer, no message in flight.","originalText":"A bridge connects two separate states. A proxy exposes one state in two places.\nProxies are synchronous and share state: no wrapped assets, no relayer, no message in flight.","fontSize":16,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#3b82f6","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":600001,"version":1,"versionNonce":600002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.4}
