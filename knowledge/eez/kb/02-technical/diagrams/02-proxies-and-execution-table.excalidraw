    {"type":"text","id":"exec_t","x":358,"y":156,"width":290,"height":180,"text":"Execution Table  (on L1)\n\n// every context switch, recorded\nCALL    UserAA -> DAO.vote()\nRETURN  DAO -> 42\nREVERT  -> unwind\n\npart of the proof: cannot be forged","originalText":"Execution Table  (on L1)\n\n// every context switch, recorded\nCALL    UserAA -> DAO.vote()\nRETURN  DAO -> 42\nREVERT  -> unwind\n\npart of the proof: cannot be forged","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":300003,"version":1,"versionNonce":300004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"exec","lineHeight":1.4},
