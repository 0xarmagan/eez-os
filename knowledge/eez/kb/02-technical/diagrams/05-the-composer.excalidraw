    {"type":"text","id":"ev_t","x":798,"y":190,"width":324,"height":82,"text":"// written BEFORE the user tx runs\nif A.call(B*) in this state -> 42\n\nso B* reads the pre-seeded answer;\none specific block, else it reverts","originalText":"// written BEFORE the user tx runs\nif A.call(B*) in this state -> 42\n\nso B* reads the pre-seeded answer;\none specific block, else it reverts","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400003,"version":1,"versionNonce":400004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"ev","lineHeight":1.4},
