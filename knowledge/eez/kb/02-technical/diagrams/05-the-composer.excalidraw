    {"type":"text","id":"pmnote","x":780,"y":300,"width":370,"height":80,"text":"Cross-chain txs need a private mempool: an\nordering requirement, not front-running. Sent\npublicly, the L1 tx lands before the state is\nseeded, and B* reverts.","originalText":"Cross-chain txs need a private mempool: an\nordering requirement, not front-running. Sent\npublicly, the L1 tx lands before the state is\nseeded, and B* reverts.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400007,"version":1,"versionNonce":400008,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.4},

    {"type":"text","id":"open","x":70,"y":430,"width":380,"height":60,"text":"Open (per the deck):\nno defined composer fee mechanism,\nand no public cross-chain tx pool yet.","originalText":"Open (per the deck):\nno defined composer fee mechanism,\nand no public cross-chain tx pool yet.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#b45309","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":500001,"version":1,"versionNonce":500002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.4}
