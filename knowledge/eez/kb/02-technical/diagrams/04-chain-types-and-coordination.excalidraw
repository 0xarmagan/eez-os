    {"type":"text","id":"valid_d","x":806,"y":182,"width":330,"height":110,"text":"Data kept off-chain. May omit\nself-chain-only txs from blobs.\nTo touch other chains, the composer\nneeds access to that off-DA data.","originalText":"Data kept off-chain. May omit\nself-chain-only txs from blobs.\nTo touch other chains, the composer\nneeds access to that off-DA data.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200017,"version":1,"versionNonce":200018,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.4},

