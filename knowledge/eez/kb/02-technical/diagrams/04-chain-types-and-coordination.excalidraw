    {"type":"text","id":"scope_t","x":96,"y":490,"width":1028,"height":50,"text":"Scope: the current core protocol targets based rollups sharing the same L1 sequencer.\nThe three-chain-type picture is the deck's broader vision, not all shipped today. EEZ is not deployed; read as roadmap.","originalText":"Scope: the current core protocol targets based rollups sharing the same L1 sequencer.\nThe three-chain-type picture is the deck's broader vision, not all shipped today. EEZ is not deployed; read as roadmap.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400003,"version":1,"versionNonce":400004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"scope","lineHeight":1.4}
