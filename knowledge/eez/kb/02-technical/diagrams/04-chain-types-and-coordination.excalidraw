    {"type":"text","id":"based_t","x":450,"y":134,"width":320,"height":20,"text":"Based / centralized-sequencer","originalText":"Based / centralized-sequencer","fontSize":17,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200009,"version":1,"versionNonce":200010,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"based","lineHeight":1.25},
    {"type":"text","id":"based_d","x":446,"y":182,"width":330,"height":110,"text":"Treated as a base rollup; state\ntransitions signed by the sequencer.\nThe sequencer must coordinate with\nthe composer to include cross-chain txs.","originalText":"Treated as a base rollup; state\ntransitions signed by the sequencer.\nThe sequencer must coordinate with\nthe composer to include cross-chain txs.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200011,"version":1,"versionNonce":200012,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.4},

