    {"type":"text","id":"native_d","x":86,"y":182,"width":330,"height":110,"text":"Own STF (WASM / RISC-V / custom).\nCross-rollup via normal Ethereum CALLs.\nETH-native: CALLs can carry ETH.\nPermissionless creation.","originalText":"Own STF (WASM / RISC-V / custom).\nCross-rollup via normal Ethereum CALLs.\nETH-native: CALLs can carry ETH.\nPermissionless creation.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":200005,"version":1,"versionNonce":200006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"lineHeight":1.4},

